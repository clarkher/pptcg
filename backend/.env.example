# =============================================
# 本地開發 (.env) — 複製此檔案為 .env 後修改
# 正式機 env vars 請在 Railway Dashboard 設定
# =============================================

# --- Database ---
# 本地：連本機 PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/pptcg"
# 正式機（Railway 自動注入，不要放進 .env）：
# DATABASE_URL="postgresql://..."

# --- Auth ---
JWT_SECRET="local-dev-secret-change-in-production"

# --- Server ---
PORT=3001

# --- CORS ---
# 本地開發填 localhost，正式機在 Railway 填 https://pipicards.com
FRONTEND_URL="http://localhost:5173"

# --- Google OAuth ---
GOOGLE_CLIENT_ID="your-google-client-id"

# --- Cloudflare Upload Worker ---
UPLOAD_WORKER_URL="https://pipicards-upload.pipicards.workers.dev/upload"
UPLOAD_WORKER_SECRET="your-upload-secret"
