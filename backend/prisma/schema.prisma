generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  username  String    @unique
  password  String?
  googleId  String?   @unique
  avatar    String?
  isAdmin   Boolean   @default(false)
  lineUid   String?   @unique  // LINE User ID — set when user binds via binding code
  createdAt DateTime  @default(now())
  listings  Listing[]
  orders    Order[]   @relation("buyer")
  cartItems CartItem[]
  wishlists     Wishlist[]
  notifications Notification[]
}

// Temporary tokens for binding LINE UID to a User account
// Generated on website, entered in LINE Bot within 10 minutes
model LineBindToken {
  code      String   @id              // 6-char alphanumeric code shown to user
  userId    String                    // The User waiting to be bound
  expiresAt DateTime                  // 10 minutes from creation
  createdAt DateTime @default(now())

  @@index([userId])
}

model Listing {
  id          String   @id @default(cuid())
  cardId      String
  cardName    String
  cardGame    String
  cardImage   String
  language    String   @default("en")    // "en" | "ja" | "zh"
  condition   String   @default("NM")
  variant     String   @default("標準")
  price       Float
  quantity    Int      @default(1)
  description String?
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  status      String   @default("active")
  createdAt   DateTime @default(now())
  cartItems   CartItem[]
  orderItems  OrderItem[]
}

// Each card entry is language-specific
// id format: "en:sv1-1" | "ja:SV1S-001" | "zh:sv1a-1"
model PokemonCard {
  id          String   @id
  language    String              // "en" | "ja" | "zh"
  setId       String              // Source set ID
  setName     String
  seriesKey   String              // Normalized: "sv" | "swsh" | "xy" etc
  seriesName  String              // Display: "Scarlet & Violet" | "スカーレット＆バイオレット"
  setLogo     String?
  releaseDate String?
  number      String
  name        String
  image       String              // Card image URL
  imageHigh   String?             // High res image
  rarity      String?
  hp          String?
  types       String?             // JSON array
  supertype   String?             // Pokémon | Trainer | Energy

  @@index([language])
  @@index([seriesKey])
  @@index([setId])
  @@index([name])
  @@index([language, seriesKey])
}

model Order {
  id              String      @id @default(cuid())
  merchantTradeNo String      @unique
  buyerId         String
  buyer           User        @relation("buyer", fields: [buyerId], references: [id])
  items           OrderItem[]
  total           Float

  paymentMethod   String      // 'credit' | 'cvs' | 'cvs_cod'
  paymentStatus   String      @default("pending")  // 'pending' | 'paid' | 'failed'
  ecpayTradeNo    String?
  cvsPaymentCode  String?
  cvsExpireDate   String?

  // 超商取貨付款 (CVS COD)
  shippingType    String?     // 'UNIMART' | 'FAMI' | 'HILIFE'
  storeId         String?
  storeName       String?
  logisticsId     String?     // ECPay AllPayLogisticsID
  bookingNote     String?     // 出貨書號

  receiverName    String?
  receiverPhone   String?

  status          String      @default("pending_payment")
  // pending_payment | paid | shipped | completed | cancelled | refunded
  refundedAt      DateTime?
  refundNote      String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])
  quantity  Int
  price     Float

  @@index([orderId])
}

model PendingCheckout {
  id            String   @id @default(cuid())
  userId        String
  cartSnapshot  Json     // CartItem[] snapshot
  receiverName  String
  receiverPhone String
  shippingType  String   // 'UNIMART' | 'FAMI' | 'HILIFE'
  storeId       String?
  storeName     String?
  storeAddress  String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([userId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  cardId    String
  cardName  String
  cardImage String
  language  String
  variant   String?
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, cardId, variant])
  @@index([cardId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   @default("restock")
  cardId    String
  cardName  String
  cardImage String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model Rarity {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  color     String @default("#64748b")
  sortOrder Int    @default(0)
}

model Series {
  id        String  @id @default(cuid())
  key       String
  name      String
  language  String
  logo      String?
  sortOrder Int     @default(0)

  @@unique([language, key])
}

model Condition {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  sortOrder Int    @default(0)
}

// ─── Admin key-value settings (LINE credentials, etc.) ───────
model Setting {
  key       String   @id     // e.g. "LINE_CHANNEL_SECRET"
  value     String           // Plain text — DB connection itself is secured
  updatedAt DateTime @updatedAt
}

// ─── Huca / 卡報報 ────────────────────────────────────────────
// Card metadata & prices sourced from huca.tw (which aggregates Snkrdunk + eBay)
// `id` = Snkrdunk product ID (used by Huca as their card ID, NOT sequential)

model HucaCard {
  id              Int       @id           // Snkrdunk product ID
  setCode         String                  // e.g. "SV9a", "S12a", "SM6"
  cardNumber      String                  // e.g. "084", "110"
  nameZh          String                  // Chinese display name from Huca
  sku             String    @unique       // e.g. "pkmn-tcg-SV9a-084" — matchable with 卡拍拍 listings
  slug            String                  // URL slug for deep-linking to huca.tw
  lowPriceTwd     Int?                    // Latest TWD low price (from Snkrdunk/eBay)
  highPriceTwd    Int?                    // Latest TWD high price
  offerCount      Int?                    // Recent transaction count (liquidity indicator)
  priceValidUntil DateTime?               // When Huca's price snapshot expires (usually +7d)
  priceUpdatedAt  DateTime?               // When we last successfully scraped a price
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([setCode])
  @@index([sku])
  @@index([priceValidUntil])
  @@index([offerCount])
}
