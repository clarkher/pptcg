generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  username  String    @unique
  password  String?
  googleId  String?   @unique
  avatar    String?
  wallet    Float     @default(1000)
  isAdmin   Boolean   @default(false)
  createdAt DateTime  @default(now())
  listings  Listing[]
  orders    Order[]   @relation("buyer")
  sales     Order[]   @relation("seller")
  wishlists     Wishlist[]
  notifications Notification[]
}

model Listing {
  id          String   @id @default(cuid())
  cardId      String
  cardName    String
  cardGame    String
  cardImage   String
  language    String   @default("en")    // "en" | "ja" | "zh"
  condition   String   @default("NM")
  variant     String   @default("標準")
  price       Float
  quantity    Int      @default(1)
  description String?
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  status      String   @default("active")
  createdAt   DateTime @default(now())
  orders      Order[]
}

// Each card entry is language-specific
// id format: "en:sv1-1" | "ja:SV1S-001" | "zh:sv1a-1"
model PokemonCard {
  id          String   @id
  language    String              // "en" | "ja" | "zh"
  setId       String              // Source set ID
  setName     String
  seriesKey   String              // Normalized: "sv" | "swsh" | "xy" etc
  seriesName  String              // Display: "Scarlet & Violet" | "スカーレット＆バイオレット"
  setLogo     String?
  releaseDate String?
  number      String
  name        String
  image       String              // Card image URL
  imageHigh   String?             // High res image
  rarity      String?
  hp          String?
  types       String?             // JSON array
  supertype   String?             // Pokémon | Trainer | Energy

  @@index([language])
  @@index([seriesKey])
  @@index([setId])
  @@index([name])
  @@index([language, seriesKey])
}

model Order {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  buyerId   String
  buyer     User     @relation("buyer", fields: [buyerId], references: [id])
  sellerId  String
  seller    User     @relation("seller", fields: [sellerId], references: [id])
  quantity  Int
  total     Float
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  cardId    String
  cardName  String
  cardImage String
  language  String
  variant   String?
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, cardId, variant])
  @@index([cardId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   @default("restock")
  cardId    String
  cardName  String
  cardImage String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model Rarity {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  color     String @default("#64748b")
  sortOrder Int    @default(0)
}

model Series {
  id        String  @id @default(cuid())
  key       String
  name      String
  language  String
  logo      String?
  sortOrder Int     @default(0)

  @@unique([language, key])
}

model Condition {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  sortOrder Int    @default(0)
}
